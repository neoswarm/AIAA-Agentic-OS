{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "sh -lc 'exec gunicorn app:app --bind 0.0.0.0:$PORT --workers \"${WEB_CONCURRENCY:-1}\" --timeout 600'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
