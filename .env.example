# ═══════════════════════════════════════════════════════════
# AIAA Agentic OS — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# Only OPENROUTER_API_KEY is required to get started.

# ───────────────────────────────────────────────────────────
# REQUIRED (you need this to use the system)
# ───────────────────────────────────────────────────────────

# Your main AI gateway — powers all 133 skills
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ───────────────────────────────────────────────────────────
# RECOMMENDED (add these when you have 10 minutes)
# ───────────────────────────────────────────────────────────

# Deep research and market intelligence
# Get one at: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Slack notifications when tasks complete
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ───────────────────────────────────────────────────────────
# OPTIONAL (add later from the dashboard or as needed)
# ───────────────────────────────────────────────────────────

# Direct Claude API access (alternative to OpenRouter)
ANTHROPIC_API_KEY=

# Direct OpenAI access (alternative to OpenRouter)
OPENAI_API_KEY=

# AI image generation (product photos, thumbnails)
# Get one at: https://fal.ai/dashboard/keys
FAL_KEY=

# Web scraping and lead generation
# Get one at: https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# ───────────────────────────────────────────────────────────
# ADVANCED (for specific workflows — add when needed)
# ───────────────────────────────────────────────────────────

# Cold email sending via Instantly
INSTANTLY_API_KEY=

# Calendar booking integration
CALENDLY_API_KEY=

# Google Docs delivery (requires service account setup)
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ───────────────────────────────────────────────────────────
# DASHBOARD (auto-configured during setup)
# ───────────────────────────────────────────────────────────

# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD_HASH=

# Flask session security
FLASK_SECRET_KEY=

# Railway API for cron management
RAILWAY_API_TOKEN=
